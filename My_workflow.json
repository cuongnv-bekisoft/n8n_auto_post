        "url": "https://fb-auto-poster.cuongnv.workers.dev/schedule",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "=={{ JSON.stringify({\n  caption: $('get_title').item.json.title_short,\n  image_url: $('Extract_URL').item.json.image_url,\n  link: $('post_web').item.json.url,\n  scheduled_time: $('Calc_time').item.json.scheduled_time,\n  page: \"0\"\n}) }}",
