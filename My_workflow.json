      "name": "Schedule_FB"
    },
    {
      "parameters": {
        "jsCode": "const loopIndex = $runIndex || 0;\n\nconst allJobs = $('Get_FB_jobs').first().json;\nconst pendingJobs = (allJobs.jobs || []).filter(j => j.status !== 'commented');\n\n// Tính ngày mai VN\nconst now = new Date();\nconst vnNow = new Date(now.getTime() + 7 * 60 * 60 * 1000);\nconst tomorrowVN = new Date(vnNow);\ntomorrowVN.setUTCDate(tomorrowVN.getUTCDate() + 1);\ntomorrowVN.setUTCHours(0, 0, 0, 0);\n\n// Các slot 30 phút từ 9h30 đến 13h\nconst slots = [\n  { h: 9,  m: 30 },\n  { h: 10, m: 0  },\n  { h: 10, m: 30 },\n  { h: 11, m: 0  },\n  { h: 11, m: 30 },\n  { h: 12, m: 0  },\n  { h: 12, m: 30 },\n  { h: 13, m: 0  },\n];\n\nlet chosenSlot = null;\n\nfor (const slot of slots) {\n  const candidate = new Date(tomorrowVN);\n  candidate.setUTCHours(slot.h - 7, slot.m, 0, 0);\n  const candidateTs = Math.floor(candidate.getTime() / 1000);\n\n  // Check trùng trong vòng 20 phút\n  const conflict = pendingJobs.some(j =>\n    Math.abs(j.scheduled_ts - candidateTs) < 1200\n  );\n\n  if (!conflict) {\n    chosenSlot = slot;\n    break;\n  }\n}\n\n// Fallback nếu hết slot\nif (!chosenSlot) chosenSlot = slots[loopIndex % slots.length];\n\n// Build ISO string đúng giờ VN\nconst scheduled = new Date(tomorrowVN);\nscheduled.setUTCHours(chosenSlot.h - 7, chosenSlot.m, 0, 0);\n\nconst pad = n => String(n).padStart(2, '0');\nconst vnDate = new Date(scheduled.getTime() + 7 * 60 * 60 * 1000);\nconst isoTime = `${vnDate.getUTCFullYear()}-${pad(vnDate.getUTCMonth()+1)}-${pad(vnDate.getUTCDate())}T${pad(chosenSlot.h)}:${pad(chosenSlot.m)}:00+07:00`;\n\nreturn {\n  scheduled_time: isoTime,\n  loop_index: loopIndex,\n  chosen_hour: `${chosenSlot.h}:${pad(chosenSlot.m)}`\n};"
      },
