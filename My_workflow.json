    {
      "parameters": {
        "jsCode": "const sources = $input.all().map(item => item.json);\n\n// Loại nguồn có id 0 và 1\nconst filtered = sources.filter(s => s.id !== 0 && s.id !== 1);\n\nconst shuffled = [...filtered].sort(() => Math.random() - 0.5);\nconst selected = shuffled.slice(0, 4);\n\nreturn selected.map(source => ({ json: source }));"
      },
